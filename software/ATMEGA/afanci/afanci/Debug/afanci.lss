void initPWM() {
	// Configure Timer0 for Fast PWM on OC0A (Pin 6) and OC0B (Pin 5)
	TCCR0A = (1 << WGM00) | (1 << WGM01) | (1 << COM0A1) | (1 << COM0B1); // Fast PWM mode
